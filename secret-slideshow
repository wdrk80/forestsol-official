<!DOCTYPE html>

<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>Secret Slideshow | Forestsol Official</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      min-height: 100%;
      background: #050806;
      color: #ffffff;
      font-family: sans-serif;
      overflow-x: hidden;
    }

    body {
      background:
        radial-gradient(circle at center, rgba(80, 160, 120, 0.18), transparent 42%),
        linear-gradient(180deg, #020403 0%, #06110c 45%, #020403 100%);
    }

    .page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 18px;
    }

    .title {
      text-align: center;
      margin-bottom: 14px;
      text-shadow: 0 0 12px rgba(120, 255, 190, 0.45);
    }

    .title h1 {
      margin: 0;
      font-size: clamp(22px, 4vw, 38px);
      color: #bdf7d5;
      letter-spacing: 0.04em;
    }

    .title p {
      margin: 8px 0 0;
      font-size: 14px;
      color: #dceee5;
      opacity: 0.9;
    }

    .slideshow-frame {
      position: relative;
      width: min(96vw, 1280px);
      aspect-ratio: 16 / 9;
      background: #000;
      border-radius: 18px;
      overflow: hidden;
      border: 1px solid rgba(154, 226, 190, 0.35);
      box-shadow:
        0 0 45px rgba(73, 183, 137, 0.25),
        0 18px 50px rgba(0, 0, 0, 0.65);
    }

    .slide-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      transform: scale(1.01);
      transition: opacity 0.08s linear;
      user-select: none;
      pointer-events: none;
    }

    .slide-img.active {
      opacity: 1;
    }

    .flash {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(255,255,255,0.25), transparent 55%);
      opacity: 0;
      pointer-events: none;
      mix-blend-mode: screen;
    }

    .flash.show {
      animation: flashPop 0.22s ease-out;
    }

    @keyframes flashPop {
      0% { opacity: 0; }
      35% { opacity: 0.55; }
      100% { opacity: 0; }
    }

    .controls {
      margin-top: 16px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
      align-items: center;
    }

    button {
      border: none;
      border-radius: 999px;
      padding: 12px 22px;
      font-weight: 700;
      font-size: 15px;
      cursor: pointer;
      color: #082018;
      background: linear-gradient(135deg, #bdf7d5, #5ed39d);
      box-shadow: 0 8px 20px rgba(0,0,0,0.35);
      transition: transform 0.15s ease, filter 0.15s ease;
    }

    button:hover {
      transform: translateY(-2px);
      filter: brightness(1.08);
    }

    .sub-button {
      background: rgba(255,255,255,0.12);
      color: #ffffff;
      border: 1px solid rgba(255,255,255,0.28);
    }

    .speed-box {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(0,0,0,0.35);
      border: 1px solid rgba(255,255,255,0.16);
      color: #dceee5;
      font-size: 14px;
    }

    .speed-box input {
      width: 120px;
    }

    .counter {
      margin-top: 10px;
      font-size: 14px;
      color: #cde6d8;
      opacity: 0.9;
      text-align: center;
    }

    .hint {
      max-width: 880px;
      margin: 14px auto 0;
      color: #cde6d8;
      opacity: 0.78;
      font-size: 13px;
      line-height: 1.7;
      text-align: center;
    }

    .back-link {
      margin-top: 18px;
      color: #bdf7d5;
      text-decoration: none;
      font-weight: 700;
      opacity: 0.9;
    }

    .back-link:hover {
      text-decoration: underline;
    }

    @media (max-width: 700px) {
      .page {
        padding: 10px;
      }

      .slideshow-frame {
        width: 100vw;
        border-radius: 0;
        border-left: none;
        border-right: none;
      }

      button {
        padding: 11px 18px;
      }

      .speed-box {
        width: min(92vw, 360px);
        justify-content: center;
      }
    }
  </style>

</head>

<body>
  <main class="page">
    <div class="title">
      <h1>Forestsol Secret Animation</h1>
      <p>ウォルフィが慌ててホームページを下ろす隠し演出</p>
    </div>

<section class="slideshow-frame" id="slideshowFrame">
  <img class="slide-img active" src="images/secret/slide/1.png" alt="slide 1">
  <img class="slide-img" src="images/secret/slide/2.png" alt="slide 2">
  <img class="slide-img" src="images/secret/slide/3.png" alt="slide 3">
  <img class="slide-img" src="images/secret/slide/4.png" alt="slide 4">
  <img class="slide-img" src="images/secret/slide/5.png" alt="slide 5">
  <img class="slide-img" src="images/secret/slide/6.png" alt="slide 6">
  <img class="slide-img" src="images/secret/slide/7.png" alt="slide 7">
  <img class="slide-img" src="images/secret/slide/8.png" alt="slide 8">
  <img class="slide-img" src="images/secret/slide/9.png" alt="slide 9">
  <img class="slide-img" src="images/secret/slide/10.png" alt="slide 10">
  <img class="slide-img" src="images/secret/slide/11.png" alt="slide 11">
  <div class="flash" id="flash"></div>
</section>

<div class="controls">
  <button onclick="playSlideshow()">再生</button>
  <button class="sub-button" onclick="pauseSlideshow()">一時停止</button>
  <button class="sub-button" onclick="replaySlideshow()">最初から</button>

  <label class="speed-box">
    速さ
    <input id="speedRange" type="range" min="80" max="650" value="180">
  </label>
</div>

<div class="counter" id="counter">1 / 11</div>

<p class="hint">
  速さは左ほど速く、右ほどゆっくり。おすすめは 150〜220 くらい。
  サイト演出に使うなら、最後の画像で止める設定にしてあるよ。
</p>

<a class="back-link" href="index.html">トップへ戻る</a>

  </main>

  <script>
    const slides = Array.from(document.querySelectorAll(".slide-img"));
    const counter = document.getElementById("counter");
    const speedRange = document.getElementById("speedRange");
    const flash = document.getElementById("flash");

    let current = 0;
    let timer = null;
    let playing = false;

    function showSlide(index) {
      slides[current].classList.remove("active");
      current = index;
      slides[current].classList.add("active");
      counter.textContent = `${current + 1} / ${slides.length}`;

      if (current === slides.length - 1) {
        flash.classList.remove("show");
        void flash.offsetWidth;
        flash.classList.add("show");
      }
    }

    function nextSlide() {
      if (current >= slides.length - 1) {
        pauseSlideshow();
        return;
      }

      showSlide(current + 1);
    }

    function playSlideshow() {
      if (playing) return;

      playing = true;
      timer = setInterval(nextSlide, Number(speedRange.value));
    }

    function pauseSlideshow() {
      playing = false;
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    }

    function replaySlideshow() {
      pauseSlideshow();
      showSlide(0);
      setTimeout(playSlideshow, 250);
    }

    speedRange.addEventListener("input", () => {
      if (playing) {
        pauseSlideshow();
        playSlideshow();
      }
    });

    slides.forEach((img) => {
      const preload = new Image();
      preload.src = img.src;
    });

    window.addEventListener("keydown", (event) => {
      if (event.code === "Space") {
        event.preventDefault();
        playing ? pauseSlideshow() : playSlideshow();
      }

      if (event.key === "ArrowRight") {
        pauseSlideshow();
        if (current < slides.length - 1) showSlide(current + 1);
      }

      if (event.key === "ArrowLeft") {
        pauseSlideshow();
        if (current > 0) showSlide(current - 1);
      }
    });
  </script>

</body>
</html>
